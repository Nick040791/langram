# Required to enable the folder picker and "like" writes. Generate a long
# random string, e.g.:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
LANGRAM_TOKEN=replace-me-with-a-long-random-string

# Optional overrides.
# PORT=3012
# GALLERY_PATH=/path/to/your/photos
# LANGRAM_MAX_DEPTH=12
# LANGRAM_MAX_FILES=50000
